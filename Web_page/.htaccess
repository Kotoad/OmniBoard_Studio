RewriteEngine On

RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Check if the requested URL is NOT an existing directory
RewriteCond %{REQUEST_FILENAME} !-d

# Check if the requested URL with a .php extension IS an existing file
RewriteCond %{REQUEST_FILENAME}.php -f

# If both conditions are met, internally route to the .php file
RewriteRule ^(.*)$ $1.php [L]